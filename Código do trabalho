int validaropção(int opção, int min, int max, string mensagemErro) {
    while (true) {
        if (cin.fail()) {
            cin.clear(); 
            cin.ignore(numeric_limits<streamsize>::max(), '\n');
            cout<<endl<<mensagemErro<<endl;
            cin>>opção;
        }
        else if (opção < min || opção > max) {
            
            cout<<mensagemErro<<endl;
            cin>>opção;
        } 
        else {
            processamento();
            return opção;
        }
    }
}

